#!/bin/bash

set -e

# Build the site
bundle exec jekyll build

# Run HTML proofer with relaxed settings
# --disable-external: Skip external link checking
# --ignore-urls: Ignore specific URLs that might be problematic
bundle exec htmlproofer ./_site \
  --disable-external \
  --ignore-urls "/rag-nasaai-spacelovers.onrender.com/,/www.linkedin.com/" \
  --check-html \
  --check-sri

# Run Rubocop for code style checking
bundle exec rubocop -D --config .rubocop.yml

# Add any additional build steps here if needed
# For example:
# - Run tests
# - Check for broken links
# - Validate HTML

bundle exec script/validate-html
gem build jekyll-theme-minimal.gemspec
